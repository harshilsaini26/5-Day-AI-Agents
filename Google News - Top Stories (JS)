#!/usr/bin/env node

const https = require('https');

// ANSI Escape Codes for styling
const styles = {
  reset: '\x1b[0m',
  bold: '\x1b[1m',
  dim: '\x1b[2m',
  italic: '\x1b[3m',
  underline: '\x1b[4m',
  cyan: '\x1b[36m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  magenta: '\x1b[35m',
  red: '\x1b[31m',
  bgBlue: '\x1b[44m',
  white: '\x1b[37m'
};

function decodeHTML(str) {
  if (!str) return '';
  return str
    .replace(/<!\[CDATA\[([\s\S]*?)\]\]>/gi, '$1')
    .replace(/&amp;/gi, '&')
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>')
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/&apos;/gi, "'")
    .replace(/&nbsp;/gi, ' ')
    .trim();
}

function fetchXML(url, redirects = 0) {
  if (redirects > 5) {
    return Promise.reject(new Error('Too many redirects'));
  }
  return new Promise((resolve, reject) => {
    https.get(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
      }
    }, (res) => {
      // Handle redirect status codes (3xx)
      if (res.statusCode >= 300 && res.statusCode < 400 && res.headers.location) {
        const redirectUrl = new URL(res.headers.location, url).toString();
        resolve(fetchXML(redirectUrl, redirects + 1));
        return;
      }

      if (res.statusCode !== 200) {
        reject(new Error(`Failed to fetch news. Status code: ${res.statusCode}`));
        return;
      }

      let data = '';
      res.on('data', (chunk) => {
        data += chunk;
      });
      res.on('end', () => {
        resolve(data);
      });
    }).on('error', (err) => {
      reject(err);
    });
  });
}

function parseRSS(xml) {
  const items = [];
  // Match XML <item> elements, allowing for namespaces or attributes inside the tag
  const itemRegex = /<item\b[^>]*>([\s\S]*?)<\/item>/g;
  let match;
  while ((match = itemRegex.exec(xml)) !== null) {
    const itemContent = match[1];
    
    // Extract title (handling potential tag attributes)
    const titleMatch = itemContent.match(/<title\b[^>]*>([\s\S]*?)<\/title>/i);
    let title = titleMatch ? titleMatch[1] : 'No Title';
    
    // Extract link
    const linkMatch = itemContent.match(/<link\b[^>]*>([\s\S]*?)<\/link>/i);
    const link = linkMatch ? linkMatch[1] : '';
    
    // Extract pubDate
    const pubDateMatch = itemContent.match(/<pubDate\b[^>]*>([\s\S]*?)<\/pubDate>/i);
    const pubDate = pubDateMatch ? pubDateMatch[1] : '';
    
    // Extract source
    const sourceMatch = itemContent.match(/<source\b[^>]*>([\s\S]*?)<\/source>/i);
    let source = sourceMatch ? sourceMatch[1] : '';

    // Clean up title (Google News titles often suffix " - Source Name")
    title = decodeHTML(title);
    source = decodeHTML(source);
    
    if (source && title.endsWith(` - ${source}`)) {
      title = title.substring(0, title.length - ` - ${source}`.length);
    }

    items.push({
      title,
      link: decodeHTML(link),
      pubDate: pubDate ? new Date(pubDate) : null,
      source: source || 'Google News'
    });
  }
  return items;
}

function formatRelativeTime(date) {
  const diffMs = Date.now() - date.getTime();
  const diffMins = Math.max(0, Math.floor(diffMs / 60000));
  const diffHours = Math.floor(diffMins / 60);
  const diffDays = Math.floor(diffHours / 24);

  if (diffMins < 60) {
    return `${diffMins}m ago`;
  } else if (diffHours < 24) {
    return `${diffHours}h ago`;
  } else {
    return `${diffDays}d ago`;
  }
}

async function main() {
  const args = process.argv.slice(2);
  const query = args.join(' ');

  let url = 'https://news.google.com/rss?hl=en-US&gl=US&ceid=US:en';
  let titleHeader = 'Google News - Top Stories';

  if (query) {
    url = `https://news.google.com/rss/search?q=${encodeURIComponent(query)}&hl=en-US&gl=US&ceid=US:en`;
    titleHeader = `Google News - Search: "${query}"`;
  }

  console.log(`\n${styles.bold}${styles.cyan}⌛ Fetching latest news from Google...${styles.reset}\n`);

  try {
    const xml = await fetchXML(url);
    const items = parseRSS(xml);

    if (items.length === 0) {
      console.log(`${styles.yellow}No news articles found.${styles.reset}\n`);
      return;
    }

    // Header Box
    const border = '━'.repeat(Math.min(process.stdout.columns || 60, 60));
    console.log(`${styles.bold}${styles.cyan}${border}`);
    console.log(`  ${styles.bold}${styles.magenta}📰 ${titleHeader}`);
    console.log(`${styles.cyan}${border}${styles.reset}\n`);

    // Limit to top 10 stories
    const topStories = items.slice(0, 10);

    topStories.forEach((item, index) => {
      const idxStr = `${index + 1}.`.padEnd(3);
      const relativeTime = item.pubDate ? formatRelativeTime(item.pubDate) : '';
      const sourceStr = `${styles.bold}${styles.green}${item.source}${styles.reset}`;
      const timeStr = relativeTime ? ` ${styles.dim}(${relativeTime})${styles.reset}` : '';

      console.log(`${styles.bold}${styles.cyan}${idxStr}${styles.reset} ${styles.bold}${item.title}`);
      console.log(`    ${sourceStr}${timeStr}`);
      if (item.link) {
        console.log(`    ${styles.underline}${styles.blue}${item.link}${styles.reset}`);
      }
      console.log();
    });

  } catch (error) {
    console.error(`\n${styles.bold}${styles.red}❌ Error fetching news:${styles.reset} ${error.message}\n`);
  }
}

main();
